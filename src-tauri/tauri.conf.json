{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UltrERP",
  "version": "0.1.0",
  "identifier": "com.ultrerp.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev -- --host 0.0.0.0 --port 1420",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "UltrERP Desktop",
        "width": 1440,
        "height": 960,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}