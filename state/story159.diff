+			category_confidence,
+			review_reason
+		FROM {quoted_schema}.product_category_review_candidates
+		WHERE tenant_id = $1 AND batch_id = $2
+		ORDER BY review_reason, legacy_code
+		""",
+        tenant_id,
+        batch_id,
+    )
+    candidates = tuple(
+        ProductCategoryReviewCandidate(
+            legacy_code=_as_text(payload.get("legacy_code")),
