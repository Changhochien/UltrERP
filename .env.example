APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://ultr_erp@localhost:5432/ultr_erp
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=["http://localhost:5173","tauri://localhost"]
VITE_API_PROXY_TARGET=http://localhost:8000
JWT_SECRET=change-this-local-jwt-secret-before-shared-use-123456

# PostHog Analytics (optional — dashboard visitor stats widget)
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=https://us.posthog.com
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.posthog.com

# MCP API Keys — JSON mapping of key → scopes.
# Format: {"<key>": ["<scope1>", "<scope2>", ...], ...}
# Example: {"test-admin-key": ["admin"], "test-agent-key": ["customers:read", "invoices:read", "inventory:read", "orders:read"]}
MCP_API_KEYS=
VITE_DEV_AUTO_LOGIN=true
