+async def _fetch_product_category_review_summary(
+    connection,
+    schema_name: str,
+    tenant_id: uuid.UUID,
+    batch_id: str,
+) -> ProductCategoryReviewSummary:
+    quoted_schema = _quoted_identifier(schema_name)
+    rows = await connection.fetch(
+        f"""
